# ══════════════════════════════════════════════════════════════════════════
# Frontend .dockerignore — Prevents bloat when building Nginx image
# ══════════════════════════════════════════════════════════════════════════

# ── SECRETS ───────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key

# ── NODE & NPM ────────────────────────────────────────────────────────────
node_modules/
npm-debug.log
npm-debug.log.*
yarn-debug.log
yarn-error.log
lerna-debug.log
pnpm-lock.yaml
package-lock.json

# ── BUILD & DIST ──────────────────────────────────────────────────────────
# Dist is built in the stage, but exclude source to reduce final image
dist/
dist-ssr/
*.local

# ── TESTING ───────────────────────────────────────────────────────────────
.vitest/
.vitest-cache/
.jest/
coverage/

# ── IDE & EDITOR ──────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.sublime-workspace

# ── GIT ───────────────────────────────────────────────────────────────────
.git/
.gitignore
.gitattributes

# ── OS ────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.lock

# ── STORYBOOK & DOCUMENTATION ────────────────────────────────────────────
storybook-static/
README.md
*.md

# ── MISC ──────────────────────────────────────────────────────────────────
*.log
*.tmp
*.temp
*.bak
.eslintcache
.prettierignore
